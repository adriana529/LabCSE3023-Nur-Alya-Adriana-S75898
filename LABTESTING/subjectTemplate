package com.lab.controller;

import com.lab.bean.StudentBean;
import com.lab.dao.StudentDAO;
import java.io.IOException;
import java.io.InputStream;
import javax.servlet.ServletException;
import javax.servlet.annotation.MultipartConfig;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;
import javax.servlet.http.HttpSession;
import javax.servlet.http.Part;

// 🔴 TUKAR/PENTING: Wajib ada tag ini kalau form HTML ada upload file/gambar!
// Kalau tak letak, Servlet takkan boleh baca file gambar yang dihantar.
@MultipartConfig(maxFileSize = 16177215) // Max saiz file: 16 MB
public class UserServlet extends HttpServlet {
    
    // Panggil DAO yang kita buat tadi
    private StudentDAO studentDAO = new StudentDAO();

    // =========================================================
    // doPost: Digunakan untuk terima data SULIT (Form Register/Login)
    // =========================================================
    @Override
    protected void doPost(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {
        
        response.setContentType("text/html;charset=UTF-8");
        
        // Baca "action" untuk tahu apa yang user nak buat
        // Biasanya dihantar melalui <input type="hidden" name="action" value="register"> dalam HTML
        String action = request.getParameter("action");

        // --- 1. HANDLE REGISTRATION (DAFTAR) ---
        if ("register".equals(action)) {
            StudentBean newStudent = new StudentBean();
            newStudent.setMatricNo(request.getParameter("matricNo"));
            newStudent.setFullname(request.getParameter("fullname"));
            newStudent.setPassword(request.getParameter("password"));
            
            InputStream inputStream = null;
            // Dapatkan fail gambar dari input file HTML (name="profileImage")
            Part filePart = request.getPart("profileImage");
            
            if (filePart != null && filePart.getSize() > 0) {
                inputStream = filePart.getInputStream(); // Tukar gambar jadi aliran air (Stream)
            }
            
            // Hantar ke DAO untuk simpan ke database
            boolean isSuccess = studentDAO.registerStudent(newStudent, inputStream);
            
            if (isSuccess) {
                response.getWriter().println("Registration Successful! <a href='login.html'>Login here</a>");
            } else {
                response.getWriter().println("Registration Failed!");
            }
        } 
        
        // --- 2. HANDLE LOGIN (LOG MASUK) ---
        else if ("login".equals(action)) {
            String matric = request.getParameter("matricNo");
            String pass = request.getParameter("password");
            
            // Pergi ke DAO, check matric dan password. Kalau betul, ia pulangkan data (termasuk gambar)
            StudentBean student = studentDAO.loginStudent(matric, pass);
            
            if (student != null) {
                // Login Berjaya: Cipta "Session" (Pasport sementara) untuk user ini
                HttpSession session = request.getSession();
                // Simpan SEMUA data pelajar (termasuk Base64 gambar) ke dalam session bernama "loggedUser"
                session.setAttribute("loggedUser", student);
                
                // Bawa user masuk ke dashboard
                response.sendRedirect("dashboard.jsp");
            } else {
                response.getWriter().println("Invalid Credentials! <a href='login.html'>Try Again</a>");
            }
        }
    }

    // =========================================================
    // doGet: Digunakan untuk request biasa/link dari URL (Logout/Delete)
    // =========================================================
    @Override
    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {
        
        String action = request.getParameter("action");
        
        // Ambil session sedia ada (jangan cipta baru)
        HttpSession session = request.getSession(false);

        // --- 3. HANDLE LOGOUT (LOG KELUAR) ---
        if ("logout".equals(action)) {
            if (session != null) {
                session.invalidate(); // Bakar pasport session! User dah tak wujud dalam sistem.
            }
            response.sendRedirect("login.html");
        }
        
        // --- 4. HANDLE DELETE ACCOUNT (PADAM AKAUN) ---
        else if ("delete".equals(action)) {
            // Check pastikan ada orang yang login sebelum padam
            if (session != null && session.getAttribute("loggedUser") != null) {
                // Keluarkan data pelajar dari session
                StudentBean user = (StudentBean) session.getAttribute("loggedUser");
                
                // Suruh DAO padam data dalam database berdasarkan Matric No
                studentDAO.deleteStudent(user.getMatricNo());
                
                session.invalidate(); // Bakar session selepas akaun dipadam
            }
            // Bawa user balik ke muka depan (Register)
            response.sendRedirect("register.html");
        }
    }
}



