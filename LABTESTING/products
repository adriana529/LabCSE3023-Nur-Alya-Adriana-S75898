<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<!DOCTYPE html>
<html>
<head>
    <title>Product Management</title>
</head>
<body>
    <h2>Product Management System</h2>
    
    <a href="products?action=new">Add New Product</a>
    <br/><br/>
    
    <table border="1" cellpadding="5">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Actions</th>
        </tr>
        <c:forEach var="product" items="${listProducts}">
            <tr>
                <td><c:out value="${product.id}" /></td>
                <td><c:out value="${product.name}" /></td>
                <td>$<c:out value="${product.price}" /></td>
                <td><c:out value="${product.quantity}" /></td>
                <td>
                    <a href="products?action=edit&id=${product.id}">Edit</a>
                    &nbsp;&nbsp;&nbsp;&nbsp;
                    <a href="products?action=delete&id=${product.id}" 
                       onclick="return confirm('Are you sure you want to delete this item?');">Delete</a>
                </td>
            </tr>
        </c:forEach>
    </table>
</body>
</html>


//jsp 
<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<!DOCTYPE html>
<html>
<head>
    <title>Product Form</title>
</head>
<body>
    <h2>
        <c:if test="${product != null}">Edit Product</c:if>
        <c:if test="${product == null}">Add New Product</c:if>
    </h2>

    <form action="products?action=<c:if test='${product != null}'>update</c:if><c:if test='${product == null}'>insert</c:if>" method="post">
        
        <c:if test="${product != null}">
            <input type="hidden" name="id" value="<c:out value='${product.id}' />" />
        </c:if>

        <table border="0" cellpadding="5">
            <tr>
                <td>Product Name:</td>
                <td><input type="text" name="name" size="45" value="<c:out value='${product.name}' />" required /></td>
            </tr>
            <tr>
                <td>Price:</td>
                <td><input type="number" step="0.01" name="price" size="45" value="<c:out value='${product.price}' />" required /></td>
            </tr>
            <tr>
                <td>Quantity:</td>
                <td><input type="number" name="quantity" size="45" value="<c:out value='${product.quantity}' />" required /></td>
            </tr>
            <tr>
                <td colspan="2" align="center">
                    <input type="submit" value="Save" />
                    &nbsp;&nbsp;
                    <a href="products?action=list">Cancel</a>
                </td>
            </tr>
        </table>
    </form>
</body>
</html>
          



