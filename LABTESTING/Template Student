package com.lab.controller;

import com.lab.bean.StudentBean; 
import com.lab.dao.StudentDAO;   
import java.io.IOException;
import java.sql.SQLException;
import java.util.List;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.*;

@WebServlet("/StudentServlet")
public class StudentServlet extends HttpServlet {
    private StudentDAO dao; 

    public void init() { dao = new StudentDAO(); } 

    protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        doGet(request, response);
    }

    protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        String action = request.getParameter("action");
        if (action == null) action = "list";

        try {
            switch (action) {
                case "new":
                    request.getRequestDispatcher("studentForm.jsp").forward(request, response);
                    break;
                case "insert":
                    String matricNo = request.getParameter("matricNo");
                    String name = request.getParameter("name");
                    dao.insertStudent(new StudentBean(0, matricNo, name));
                    
                    response.sendRedirect("StudentServlet?action=list");
                    break;
                case "edit":
                    int editId = Integer.parseInt(request.getParameter("id"));
                    request.setAttribute("studentData", dao.selectStudent(editId)); 
                    request.getRequestDispatcher("studentForm.jsp").forward(request, response);
                    break;
                case "update":
                    int upId = Integer.parseInt(request.getParameter("id"));
                    String upMatric = request.getParameter("matricNo");
                    String upName = request.getParameter("name");
                    dao.updateStudent(new StudentBean(upId, upMatric, upName));
                    
                    response.sendRedirect("StudentServlet?action=list");
                    break;
                case "delete":
                    int delId = Integer.parseInt(request.getParameter("id"));
                    dao.deleteStudent(delId);
                    
                    response.sendRedirect("StudentServlet?action=list");
                    break;
                default: 
                    List<StudentBean> listStudents = dao.selectAllStudents();
                    request.setAttribute("listArray", listStudents);
                    request.getRequestDispatcher("studentList.jsp").forward(request, response);
                    break;
            }
        } catch (SQLException ex) {
            throw new ServletException(ex);
        }
    }
}


